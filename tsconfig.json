{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "allowJs": true,
    "isolatedModules": true,
    "lib": ["DOM", "ES2020"]
  },
  "include": ["api/**/*"],
  "exclude": ["node_modules"]
}
